<!DOCTYPE html>
@{
    Layout = null;
}
<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Login - ItemPro</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/style.css" />
    <style>
        body {
            background: linear-gradient(135deg, #3d78f1 0%, #21b8cb 100%);
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            margin: 0;
            font-family: 'Inter', sans-serif;
            color: #1a1a2e;
        }

        .login-card {
            background: white;
            padding: 50px 40px;
            border-radius: 24px;
            box-shadow: 0 15px 35px rgba(0,0,0,0.1);
            width: 100%;
            max-width: 440px;
            text-align: center;
            box-sizing: border-box;
        }

        .logo-box {
            width: 48px;
            height: 48px;
            background: linear-gradient(135deg, #3d78f1 0%, #21b8cb 100%);
            border-radius: 12px;
            display: flex;
            justify-content: center;
            align-items: center;
            margin: 0 auto 20px;
            color: white;
            font-size: 24px;
        }

        .login-title {
            font-size: 28px;
            font-weight: 700;
            margin-bottom: 8px;
        }

        .login-subtitle {
            font-size: 14px;
            color: #8e8e93;
            margin-bottom: 32px;
        }

        .form-group {
            text-align: left;
            margin-bottom: 24px;
        }

            .form-group label {
                display: block;
                margin-bottom: 8px;
                font-weight: 600;
                font-size: 13px;
            }

            .form-group input {
                width: 100%;
                padding: 14px;
                border: 1px solid #e5e5ea;
                border-radius: 10px;
                font-size: 15px;
                box-sizing: border-box;
                background: #fafafa;
                transition: border-color 0.2s;
            }

                .form-group input:focus {
                    outline: none;
                    border-color: #5e5ce6;
                }

        .btn-login {
            width: 100%;
            padding: 16px;
            background: #5e5ce6;
            color: white;
            border: none;
            border-radius: 12px;
            font-weight: 600;
            font-size: 16px;
            cursor: pointer;
            transition: transform 0.2s, background 0.2s;
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 8px;
        }

            .btn-login:hover {
                background: #4a48c6;
                transform: translateY(-1px);
            }

        .demo-hint {
            margin-top: 24px;
            font-size: 12px;
            color: #8e8e93;
        }

            .demo-hint b {
                color: #1a1a2e;
            }

        .error-msg {
            color: #ff3b30;
            font-size: 14px;
            margin-top: 15px;
            font-weight: 500;
        }
    </style>
</head>
<body>
    <div class="login-card">
        <div class="logo-box">&#9881;</div>
        <div class="login-title">Item Processing System</div>
        <div class="login-subtitle">Sign in to continue to your dashboard</div>

        <form asp-action="Login" method="post">
            <div class="form-group">
                <label>Email Address</label>
                <input type="email" name="Email" required placeholder="admin@example.com" />
            </div>
            <div class="form-group">
                <label>Password</label>
                <input type="password" name="Password" required placeholder="Enter password" />
            </div>

            <button type="submit" class="btn-login">
                <span>&#128274;</span> Sign In
            </button>

            @if (ViewBag.Error != null)
            {
                <div class="error-msg">@ViewBag.Error</div>
            }
        </form>

        <div class="demo-hint">
            Demo: <b>admin@example.com</b> / <b>admin123</b>
        </div>
    </div>
</body>
</html>
