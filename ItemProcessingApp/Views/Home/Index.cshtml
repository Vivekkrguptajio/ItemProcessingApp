<!DOCTYPE html>
@{
    Layout = null;
}
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="~/css/style.css" />
<!-- jsTree themes -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/jstree/3.3.12/themes/default/style.min.css" />

<!-- MAIN APP -->
<div class="page active" id="appPage">
    <div class="sidebar">
        <div class="sidebar-logo">
            <div class="icon">&#9881;</div>
            <span>ItemPro</span>
        </div>
        <div class="nav-item active" id="nav-dashboard" onclick="switchTab('dashboard',this)"><span class="nav-icon">&#127968;</span> Dashboard</div>
        <div class="nav-item" id="nav-items" onclick="switchTab('items',this)"><span class="nav-icon">&#128230;</span> Items</div>
        <div class="nav-item" id="nav-process" onclick="switchTab('process',this)"><span class="nav-icon">&#9889;</span> Process Item</div>
        <div class="nav-item" id="nav-processed" onclick="switchTab('processed',this)"><span class="nav-icon">&#10003;</span> Processed List</div>
        <div class="nav-item" id="nav-tree" onclick="switchTab('tree',this)"><span class="nav-icon">&#127795;</span> Tree View</div>
        <div class="sidebar-footer">
            <div class="user-info">
                <div class="user-avatar">A</div>
                <div><div class="user-name">Admin</div><div class="user-role">Administrator</div></div>
                <button class="logout-btn" id="logoutBtn" title="Logout">&#128682;</button>
            </div>
        </div>
    </div>

    <div class="content">
        <!-- DASHBOARD -->
        <div class="tab-content active" id="tab-dashboard">
            <div class="page-header"><div><h2>Dashboard</h2><p>Overview of your system</p></div></div>
            <div class="stats-grid">
                <div class="stat-card"><div class="stat-icon">&#128230;</div><div class="stat-val" id="stat-total">0</div><div class="stat-label">Total Items</div></div>
                <div class="stat-card"><div class="stat-icon">&#10003;</div><div class="stat-val" id="stat-processed">0</div><div class="stat-label">Processed</div></div>
                <div class="stat-card"><div class="stat-icon">&#8987;</div><div class="stat-val" id="stat-pending">0</div><div class="stat-label">Unprocessed</div></div>
                <div class="stat-card"><div class="stat-icon">&#128100;</div><div class="stat-val" id="stat-children">0</div><div class="stat-label">Child Items</div></div>
            </div>
            <div class="card">
                <div class="card-title">Recent Items</div>
                <div class="table-wrap">
                    <table>
                        <thead><tr><th>Item Name</th><th>Weight</th><th>Status</th></tr></thead>
                        <tbody id="dashRecentTable"></tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- ITEMS -->
        <div class="tab-content" id="tab-items">
            <div class="page-header">
                <div><h2>&#128230; Items</h2><p>Manage all items</p></div>
                <button class="btn btn-primary" id="addItemBtn">&#43; Add Item</button>
            </div>
            <div class="search-bar">
                <input type="text" id="searchInput" placeholder="Search items by name..." />
            </div>
            <div class="card">
                <div class="table-wrap">
                    <table>
                        <thead><tr><th>#</th><th>Item Name</th><th>Weight</th><th>Status</th><th>Actions</th></tr></thead>
                        <tbody id="itemsTableBody"></tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- PROCESS -->
        <div class="tab-content" id="tab-process">
            <div class="page-header"><div><h2>&#9889; Process Item</h2><p>Select parent and define child outputs</p></div></div>
            <div class="card">
                <div class="card-title">Processing Configuration</div>
                <div class="form-group">
                    <label>Select Parent Item</label>
                    <select id="parentSelect"><option value="">-- Select an item --</option></select>
                    <div class="err-msg" id="parentErr">Please select a parent item.</div>
                </div>
                <div class="form-group"><label>Child Output Items</label></div>
                <div id="childrenContainer"></div>
                <button class="add-child-btn" id="addChildBtn">&#43; Add Child Item</button>
                <div style="margin-top:24px;display:flex;gap:12px">
                    <button class="btn btn-primary" id="processBtn">&#9889; Process Item</button>
                    <button class="btn btn-secondary" id="resetBtn">&#8635; Reset</button>
                </div>
            </div>
        </div>

        <!-- PROCESSED LIST -->
        <div class="tab-content" id="tab-processed">
            <div class="page-header"><div><h2>&#10003; Processed Items</h2><p>All processed relationships</p></div></div>
            <div class="card">
                <div class="table-wrap">
                    <table>
                        <thead><tr><th>#</th><th>Parent Item</th><th>Parent Weight</th><th>Child Items</th><th>Total Child Weight</th></tr></thead>
                        <tbody id="processedTableBody"></tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="tab-content" id="tab-tree">
            <div class="page-header"><div><h2>&#127795; Tree View</h2><p>Parent-child hierarchy</p></div></div>
            <div class="card">
                <div class="tree-info">
                    <span class="tree-info-icon">&#127795;</span>
                    Click on a parent to expand/collapse its children. The hierarchy shows all processing relationships.
                </div>
                <div id="jstree_container"></div>
            </div>
        </div>
    </div>
</div>

<!-- ADD/EDIT MODAL -->
<div class="modal-overlay" id="itemModal">
    <div class="modal">
        <h3 id="modalTitle">Add New Item</h3>
        <div class="form-group">
            <label>Item Name</label>
            <input type="text" id="modalName" placeholder="e.g. Wheat" />
            <div class="err-msg" id="modalNameErr">Item name is required.</div>
        </div>
        <div class="form-group">
            <label>Weight (kg)</label>
            <input type="number" id="modalWeight" placeholder="e.g. 100" min="0.01" step="0.01" />
            <div class="err-msg" id="modalWeightErr">Enter a valid positive weight.</div>
        </div>
        <div class="modal-footer">
            <button class="btn btn-secondary" id="cancelModalBtn">Cancel</button>
            <button class="btn btn-success" id="saveItemBtn">&#128190; Save</button>
        </div>
    </div>
</div>

<!-- DELETE MODAL -->
<div class="modal-overlay" id="deleteModal">
    <div class="modal" style="max-width:380px;text-align:center">
        <div style="font-size:48px;margin-bottom:12px">&#128465;</div>
        <h3>Delete Item?</h3>
        <p style="color:var(--text-muted);font-size:14px;margin:12px 0 24px">This action cannot be undone.</p>
        <div class="modal-footer" style="justify-content:center">
            <button class="btn btn-secondary" id="cancelDeleteBtn">Cancel</button>
            <button class="btn btn-danger" id="confirmDeleteBtn">&#128465; Delete</button>
        </div>
    </div>
</div>

<div class="toast" id="toast"></div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.6.4/jquery.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jstree/3.3.12/jstree.min.js"></script>
<script src="~/js/app.js?v=@DateTime.Now.Ticks"></script>